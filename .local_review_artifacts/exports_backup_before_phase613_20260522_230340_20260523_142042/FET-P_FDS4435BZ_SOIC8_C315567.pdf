    <div class="accordion row">
        <div class="table-text-area"> <!-- accordion-item -->
            <h4 class="table-text-header mb-0"> <!-- accordion-header -->
                <button class="table-text-button bg-transparent shadow-none border-0 ps-0 pt-5 pb-5 pe-none" type="button"
                        aria-expanded="true"> <!-- accordion-button -->
                    <div class="row row-cols-2 align-items-center">
                        <div class="col-auto table-name">
                            <p class="mb-0 fw-bold fs-4">Documents</p> <!-- table name-->
                        </div>
                        <div class="col-auto table-size">
                            <p class="mb-0 fw-bold fs-4">(size)</p> <!-- table size-->
                        </div>
                    </div>
                </button>
            </h4>
        </div>
    </div>
    <!-- table box header end -->


    <!-- table start -->
    <div class="border shadow-sm rounded-5 table mobile-table mobile-table-collapse template-dark"
         role="table"
         aria-label="Documents"
         data-table-url="/documents/search/html"
         data-table-data-id="1"
         data-table-data-type="docSW" data-table-pagination="0" data-accordion="0" data-accordion-state="show" data-filter-json="0" data-no-container="0" data-sorted="true" data-breakpoint="768">

        
    <!-- table header -->
    <div class="d-table-header-group rounded-top-5 bg-light">
        <!-- table header row -->
        <div class="d-table-row d-flex border-bottom bg-primary text-white rounded-top-5">
            
                <!-- table header column -->
                <div class="border-end d-table-cell d-flex align-items-center p-4 col-6 sort-cell" data-type="title" data-direction="asc">
                    <div class="cell-row d-flex align-items-center">
                        <span class="header-cell-text me-1">Name / Description</span> <!-- table header column text -->
                    </div>
                </div>
                <!-- table header column end -->
            
                <!-- table header column -->
                <div class="border-end d-table-cell d-flex align-items-center p-4 col-2 sort-cell" data-type="name" data-direction="asc">
                    <div class="cell-row d-flex align-items-center">
                        <span class="header-cell-text me-1">Document ID</span> <!-- table header column text -->
                    </div>
                </div>
                <!-- table header column end -->
            
                <!-- table header column -->
                <div class="border-end d-table-cell d-flex align-items-center p-4 col-2 sort-cell" data-type="type" data-direction="asc">
                    <div class="cell-row d-flex align-items-center">
                        <span class="header-cell-text me-1">Document Type</span> <!-- table header column text -->
                    </div>
                </div>
                <!-- table header column end -->
            
                <!-- table header column -->
                <div class="border-end d-table-cell d-flex align-items-center p-4 col-2 sort-cell" data-type="publishDate" data-direction="asc">
                    <div class="cell-row d-flex align-items-center">
                        <span class="header-cell-text me-1">Revision Date</span> <!-- table header column text -->
                    </div>
                </div>
                <!-- table header column end -->
            
        </div>
        <!-- table header row end -->
    </div>
    <!-- table header end -->


        
    <div class="d-table-row-group table-body card-group row-cols-1">

        
    <div class="overlay-loading d-none d-flex position-absolute h-100 w-100 z-index-4
        align-items-center justify-content-center bg-white-500"
         aria-hidden="true"
         role="row">

        <div class="d-flex justify-content-center overlay-loading-bar"
             role="cell">

            <div class="spinner-border text-secondary">
                <span class="sr-only"></span>
            </div>
        </div>
        <div class="overlay-loading-text">
            <span class="d-none overlay-text ps-2">Loading...</span>
        </div>
    </div>


        
        
    </div>


        
    <!-- Show more row-->
    <div class="d-table-row-group show-more-row d-none bg-light rounded-bottom-5 border-top">
        <div class="d-table-row align-items-center">
            <div class="showMore p-4" type="button">
                <div class="d-flex d-table-cell">
                    <div class="row row-cols-2">
                        <div class="col-auto d-flex align-items-center pe-0">
                            <p class="mb-0 text-nowrap fw-bold">Show More</p>
                        </div>
                        <div class="col-auto ps-1">
                            <i class="bi bi-chevron-down text-secondary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Show more row end-->


        
    <!-- Table pagination row -->
    <div class="mobile-table-pagination d-none rounded-bottom-5 pt-5 pt-sm-0 bg-sm-white bg-transparent"
         role="row"
         data-page="1"
         data-pagination="enabled">
        <div class="border rounded-3 d-flex align-items-center justify-content-between p-2 bg-white"
             role="cell">
            <div class="col-auto status-page fw-bold">
                <p class="mb-0">1-25 of 25</p>
            </div>
            <div class="col-auto">
                <div class="row">
                    <button class="col-auto previous-page btn-pure"
                            aria-label="Previous page"
                            data-event="previous"
                            type="button">
                        <i class="bi bi-chevron-left"
                           data-event="previous"></i>
                    </button>
                    <button class="col-auto next-page btn-pure"
                            aria-label="Next page"
                            data-event="next"
                            type="button">
                        <i class="bi bi-chevron-right"
                           data-event="next"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class=""
             role="cell">
            <div class="d-flex p-0 pt-2 justify-content-between">
                <div class="col-auto listing pe-0">
                    <div class="row">
                        <div class="col-auto d-flex align-items-center pe-0">
                            <p class="mb-0 text-muted">
                                Products per page</p>
                            
                        </div>

                        <div class="col-auto ps-0 pe-0">
                            <select class="form-select border-0 item-per-page pe-6 ps-2 shadow-none bg-transparent"
                                    aria-label="Select item per page"
                                    data-event="itemPerPage">
                                
                                    <option value="25" selected="selected">
                                        <p class="mb-0">25</p>
                                    </option>
                                
                                    <option value="50">
                                        <p class="mb-0">50</p>
                                    </option>
                                
                                    <option value="100">
                                        <p class="mb-0">100</p>
                                    </option>
                                
                            </select>
                        </div>
                    </div>
                </div>
                <div class="col-auto page-select text-end d-flex align-items-center pe-0">
                    <div class="row">
                        <div class="col-auto">
                            <p class="mb-0 text-muted">Jump to : </p>
                        </div>

                        <div class="col-auto ps-0">
                            <div class="dropdown">
                                <span class="current-page-jump-to">1</span>

                                <button class="dropdown-toggle btn-pure"
                                        aria-label="Jump to"
                                        type="button"
                                        id="dropdownMenuButton2"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                    <i class="bi bi-chevron-down fs-7 ps-1 d-none"></i>
                                </button>

                                <ul class="dropdown-menu jump-to-page col-auto overflow-auto"
                                    aria-labelledby="dropdownMenuButton2"
                                    data-event="jumpToPage"
                                    style="min-width: 4rem; max-height: 140px;">
                                </ul>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    <!-- Table pagination row -->

    </div>
    <!-- table end -->
</div>
        </div>

        <div id="documentSearchMessageModal" class="modal py-8" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary message-modal-ok-btn" data-bs-dismiss="modal">Ok</button>
            </div>
        </div>
    </div>
</div>
        <div id="additionalInfoModal" class="modal py-8" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Additional information required</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="additional-info-form" class="needs-validation" novalidate>
                    <div>
                        <p>Please provide the needed data.</p>
                    </div>
                    <div id="additional-info-SerialNumber-row" class="form-floating my-2">
                        <input id="additional-info-SerialNumber-field" type="text"
                               class="form-control"
                               placeholder="Additional Info - Serial Number"
                               maxlength="50">
                        <label for="additional-info-SerialNumber-field">Additional Info - Serial Number</label>
                        <div class="invalid-feedback">Please enter valid Serial Number</div>
                    </div>
                    <div id="additional-info-NDANumber-row" class="form-floating my-2">
                        <input id="additional-info-NDANumber-field" type="text"
                               class="form-control"
                               placeholder="Additional Info - NDA Number"
                               maxlength="50">
                        <label for="additional-info-NDANumber-field">Additional Info - NDA Number</label>
                        <div class="invalid-feedback">Please enter valid NDA Number</div>
                    </div>
                    <div id="additional-info-OrderNumber-row" class="form-floating my-2">
                        <input id="additional-info-OrderNumber-field" type="text"
                               class="form-control"
                               placeholder="Additional Info - Order Number"
                               maxlength="50">
                        <label for="additional-info-OrderNumber-field">Additional Info - Order Number</label>
                        <div class="invalid-feedback">Please enter valid Order Number</div>
                    </div>
                    <div id="additional-info-FaeRep-row" class="form-floating my-2">
                        <input id="additional-info-FaeRep-field" type="text"
                               class="form-control"
                               placeholder="Additional Info - Fae Rep"
                               maxlength="50">
                        <label for="additional-info-FaeRep-field">Additional Info - Fae Rep</label>
                        <div class="invalid-feedback">Please enter valid Fae Rep</div>
                    </div>
                    <div id="additional-info-ApplicationType-row" class="form-floating my-2">
                        <input id="additional-info-ApplicationType-field" type="text"
                               class="form-control"
                               placeholder="Additional Info - Application Type"
                               maxlength="50">
                        <label for="additional-info-ApplicationType-field">Additional Info - Application Type</label>
                        <div class="invalid-feedback">Please enter valid Application Type</div>
                    </div>
                    <div>
                        <p>If you need assistance, contact <a href="/support/sales">sales</a>.</p>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary additional-info-modal-ok-btn" data-for-document-id="">Ok</button>
            </div>
        </div>
    </div>
</div>

    </div>

</main>
